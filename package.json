{
  "name": "review-slide-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "node --watch server/index.mjs",
    "dev": "concurrently -k \"npm:server:dev\" \"npm:client:dev\"",
    "typecheck": "vue-tsc -b",
    "test": "npm run test:all",
    "test:all": "vitest run tests",
    "test:client": "vitest run tests/client",
    "test:server": "vitest run tests/server",
    "verify": "npm run test:all && npm run build",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "lucide-vue-next": "^0.577.0",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
